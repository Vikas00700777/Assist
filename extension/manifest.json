{
  "manifest_version": 3,
  "name": "X Assistant",
  "version": "1.0.0",
  "description": "AI-powered assistant for generating smart replies for X posts and replies.",

  "action": {
    "default_title": "X Assistant",
    "default_popup": "popup/popup.html"
  },

  "permissions": [
    "storage",
    "activeTab",
    "clipboardWrite",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "https://assist-qw4s.onrender.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/capture.css"
      ]
    }
  ]
}
